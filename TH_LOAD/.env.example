# ============================================================
# Private environment variables for TH_LOAD workflow
# ============================================================

# Cloud Optimo credentials
OPTIMO_API_KEY=your_api_key_here
OPTIMO_APP_ID=your_app_id_here
OPTIMO_APP_SECRET=your_app_secret_here

# Dataset creation
THERMAL_DATASET_START_DATE=2024-12-03
THERMAL_DATASET_END_DATE=today
THERMAL_DATASET_PATH=TH_LOAD/dataset_thermal_clean.xlsx

# Paths
THERMAL_MODELS_DIR=TH_LOAD/models
THERMAL_RESULTS_DIR=TH_LOAD/results
THERMAL_FORECASTS_DIR=TH_LOAD/forecasts
THERMAL_METRICS_PATH=TH_LOAD/results/metrics_summary_thermal.xlsx

# Site and timezone
LATITUDE=45.4643
LONGITUDE=9.1895
LOCAL_TIMEZONE=Europe/Rome

# Thermal target Optimo variable IDs
THERMAL_LOAD_VAR_ID=XVpGIF_pHutx0
DH_THERMAL_LOAD_VAR_ID=XVpGIF_Ai5Ip9

# Forecast upload Optimo variable IDs
OPTIMO_THERMAL_FORECAST_VARIABLE_ID=your_thermal_forecast_variable_id_here
OPTIMO_DH_THERMAL_FORECAST_VARIABLE_ID=your_dh_thermal_forecast_variable_id_here
UPLOAD_TO_OPTIMO=true

# Model training
THERMAL_TRAIN_END=2025-04-30T23:59:00
THERMAL_TEST_START=2025-05-01T00:00:00
THERMAL_FINAL_TRAINING_DAYS=365
THERMAL_INITIAL_HISTORY_DAYS=370
THERMAL_WEATHER_DATA_DELAY_DAYS=2
THERMAL_LAG_HOURS=48,72,96,120,144,168
THERMAL_CV_SPLITS=3
RANDOM_STATE=42

# Thermal-specific rules
THERMAL_UPPER_CAP_KW=13000
THERMAL_SUMMER_ZERO_MONTHS=5,6,7,8,9
THERMAL_LAG_CAP_KW=13000

# Automatic forecasting
THERMAL_FORECAST_DATE=tomorrow
THERMAL_HISTORICAL_LOOKBACK_DAYS=8
THERMAL_MIN_LAG_HOURS=48