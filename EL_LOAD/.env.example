# Cloud Optimo credentials
OPTIMO_API_KEY=your_api_key_here
OPTIMO_APP_ID=your_app_id_here
OPTIMO_APP_SECRET=your_app_secret_here

# Dataset creation
DATASET_START_DATE=2024-05-30
DATASET_END_DATE=2025-09-30
DATASET_PATH=EL_LOAD/dataset.xlsx

# Model training
MODELS_DIR=EL_LOAD/models
RESULTS_DIR=EL_LOAD/results
METRICS_PATH=EL_LOAD/results/metrics_summary.xlsx

TRAIN_MIN_DATE=2024-06-08T08:00:00
TEST_SPLIT_DATE=2025-06-08T23:59:00

BAD_DATA_START=2025-02-07T21:45:00
BAD_DATA_END=2025-02-13T05:45:00

FINAL_TRAINING_DAYS=365
INITIAL_HISTORY_DAYS=370
WEATHER_DATA_DELAY_DAYS=2

LAG_HOURS=48,72,96,120,144,168
CV_FOLDS=3
RANDOM_STATE=42

# Automatic forecasting
FORECAST_DATE=tomorrow
FORECASTS_DIR=EL_LOAD/forecasts
LOCAL_TIMEZONE=Europe/Rome

HISTORICAL_LOOKBACK_DAYS=8
MIN_LAG_HOURS=48

UPLOAD_TO_OPTIMO=true
OPTIMO_FORECAST_NET_VARIABLE_ID=your_net_forecast_variable_id_here
OPTIMO_FORECAST_GROSS_VARIABLE_ID=your_gross_forecast_variable_id_here

# Site coordinates
LATITUDE=45.4643
LONGITUDE=9.1895